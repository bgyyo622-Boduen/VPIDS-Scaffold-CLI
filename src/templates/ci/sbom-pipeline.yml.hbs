# [AICA_CONSTRAINT_ENFORCEMENT]
# Software Bill of Materials (SBOM) Generation and SAST Scan MUST run on every PR.
# This intercepts Hallucinated Dependencies generated by LLMs.

name: VPIDS Security Gate

on:
  pull_request:
    branches: [ "main" ]

jobs:
  supply-chain-security:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Generate SBOM (Software Bill of Materials)
        uses: anchore/sbom-action@v0
        with:
          format: spdx-json
          output-file: {{projectName}}-sbom.spdx.json

      - name: Upload SBOM Artifact
        uses: actions/upload-artifact@v4
        with:
          name: sbom
          path: {{projectName}}-sbom.spdx.json

      - name: Run Dependency Vulnerability Scan
        uses: anchore/scan-action@v3
        with:
          sbom: {{projectName}}-sbom.spdx.json
          fail-build: true
          severity-cutoff: high
